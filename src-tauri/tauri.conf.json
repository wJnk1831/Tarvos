{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tarvos",
  "version": "1.1.1",
  "identifier": "com.tarvos.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tarvos",
        "fullscreen": true,
        "visible": false,
        "transparent": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/tesseract-x86_64-pc-windows-msvc.exe",
      "binaries/*.dll",
      "resources/tessdata"
    ]
  }
}
